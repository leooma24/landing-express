---
import { business } from '../../config';
---

<section id="ubicacion" class="section-pad bg-fondo">
  <div class="wrap">
    <div class="section-divider" data-reveal="fade">
      <p class="meta-label">{business.mostrarNumeros ? '04 · ' : ''}Visítanos</p>
      <p class="meta-number">{business.direccion.ciudad}</p>
    </div>

    <div class="mb-16 grid items-end gap-8 lg:grid-cols-2">
      <h2 data-reveal="left" class="font-display text-display font-semibold text-texto">
        Pase por aquí.
      </h2>
      <p data-reveal="right" style="--reveal-delay: 150ms;" class="text-base leading-relaxed text-tenue md:text-lg">
        Estamos en una ubicación fácil de llegar, con estacionamiento cercano y señalización clara.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr]">
      <div data-reveal="left" class="overflow-hidden border border-linea figure-shape">
        <iframe
          src={business.direccion.mapaEmbed}
          width="100%"
          height="520"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Ubicación de ${business.nombre}`}
        ></iframe>
      </div>

      <div class="flex flex-col divide-y divide-linea border-y border-linea">
        <div data-reveal="right" style="--reveal-delay: 100ms;" class="py-6">
          <p class="meta-label mb-3">Dirección</p>
          <p class="text-lg font-medium text-texto">{business.direccion.calle}</p>
          <p class="text-sm text-tenue">
            {business.direccion.ciudad}, {business.direccion.estado} · CP {business.direccion.codigoPostal}
          </p>
        </div>

        <div data-reveal="right" style="--reveal-delay: 250ms;" class="py-6">
          <p class="meta-label mb-3">Horarios</p>
          <dl class="space-y-1.5 text-sm">
            {business.horarios.map((h) => (
              <div class="flex items-baseline justify-between gap-4">
                <dt class="text-texto">{h.dia}</dt>
                <dd class="font-mono tabular-nums text-tenue">
                  {h.cerrado ? 'Cerrado' : `${h.apertura} — ${h.cierre}`}
                </dd>
              </div>
            ))}
          </dl>
        </div>

        <div data-reveal="right" style="--reveal-delay: 400ms;" class="py-6">
          <p class="meta-label mb-3">Contacto</p>
          <a href={`tel:${business.telefono.replace(/\s/g, '')}`} class="block w-fit text-lg font-medium text-texto link-underline hover:text-primario">
            {business.telefono}
          </a>
          <a href={`mailto:${business.email}`} class="mt-1 block w-fit text-sm text-tenue link-underline hover:text-texto">
            {business.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
