---
import { business } from '../../config';

const stats = business.sobreNosotros.estadisticas ?? [];
---

<section id="nosotros" class="section-pad bg-fondo">
  <div class="wrap">
    <div class="section-divider" data-reveal="fade">
      <p class="meta-label">{business.mostrarNumeros ? '02 · ' : ''}Nosotros</p>
      <p class="meta-number">—</p>
    </div>

    <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:gap-20">
      <figure data-reveal="image" class="reveal-image">
        <div class="aspect-[4/5] overflow-hidden figure-shape">
          <img
            src={business.sobreNosotros.imagen}
            alt={business.sobreNosotros.titulo}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        {business.mostrarNumeros && (
          <figcaption class="mt-3 flex items-baseline justify-between font-mono text-[11px] uppercase tracking-[0.15em] text-tenue">
            <span>Fig. 02</span>
            <span>{business.nombre}</span>
          </figcaption>
        )}
      </figure>

      <div class="lg:pt-10">
        <h2 data-reveal="right" class="font-display text-display font-semibold text-texto">
          {business.sobreNosotros.titulo}
        </h2>
        <p data-reveal="right" style="--reveal-delay: 150ms;" class="mt-6 text-base leading-relaxed text-tenue md:text-lg">
          {business.sobreNosotros.texto}
        </p>

        {stats.length > 0 && (
          <dl
            class="mt-12 grid divide-x divide-linea border-y border-linea py-6"
            style={`grid-template-columns: repeat(${stats.length}, 1fr);`}
          >
            {stats.map((stat, i) => (
              <div
                data-reveal="up"
                style={`--reveal-delay: ${i * 120}ms;`}
                class="px-2 text-center md:px-4 md:text-left"
              >
                <dt class="meta-label">{stat.etiqueta}</dt>
                <dd class="mt-2 font-display text-3xl font-semibold tracking-tight text-texto md:text-4xl">
                  {stat.valor}
                </dd>
              </div>
            ))}
          </dl>
        )}
      </div>
    </div>
  </div>
</section>
