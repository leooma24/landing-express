---
import { business } from '../../config';

const waHref = `https://wa.me/${business.whatsapp}?text=${encodeURIComponent(business.whatsappMensaje)}`;
const formspreeAction = `https://formspree.io/f/${business.formspreeId}`;
---

<section id="contacto" class="section-pad bg-texto text-fondo">
  <div class="wrap">
    <div class="mb-16 flex items-baseline justify-between border-b border-fondo/10 pb-5" data-reveal="fade">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fondo/50">
        {business.mostrarNumeros ? '05 · ' : ''}Contacto
      </p>
      <p class="font-mono text-sm tabular-nums text-fondo/50">Respuesta &lt; 1h</p>
    </div>

    <div class="grid gap-16 lg:grid-cols-[1.1fr_1fr] lg:gap-24">
      <div>
        <h2 data-reveal="left" class="font-display text-display font-semibold" style="color: rgb(var(--color-fondo));">
          Hablemos.
        </h2>
        <p data-reveal="left" style="--reveal-delay: 150ms;" class="mt-6 max-w-md text-base leading-relaxed text-fondo/70 md:text-lg">
          Escríbenos por WhatsApp o por el formulario. Respondemos el mismo día, siempre.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href={waHref} target="_blank" rel="noopener" class="btn-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z" />
            </svg>
            WhatsApp
          </a>
          <a href={`tel:${business.telefono.replace(/\s/g, '')}`} class="btn border border-fondo/20 bg-transparent text-fondo hover:bg-fondo hover:text-texto">
            {business.telefono}
          </a>
        </div>

        <div class="mt-16 flex items-center gap-5">
          {business.redes.facebook && (
            <a href={business.redes.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="text-fondo/50 transition hover:text-fondo">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
          {business.redes.instagram && (
            <a href={business.redes.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="text-fondo/50 transition hover:text-fondo">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M12 2.163c3.204 0 3.584.012 4.849.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.849.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          )}
          {business.redes.tiktok && (
            <a href={business.redes.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="text-fondo/50 transition hover:text-fondo">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <form action={formspreeAction} method="POST" data-reveal="right" style="--reveal-delay: 200ms;" class="divide-y divide-fondo/10 border-y border-fondo/10">
        <div class="py-4">
          <label for="nombre" class="font-mono text-[11px] uppercase tracking-[0.18em] text-fondo/50">Nombre</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="mt-1.5 w-full border-0 bg-transparent p-0 font-display text-xl font-semibold tracking-tight text-fondo placeholder-fondo/30 focus:outline-none focus:ring-0"
            placeholder="Tu nombre completo"
          />
        </div>
        <div class="py-4">
          <label for="telefono" class="font-mono text-[11px] uppercase tracking-[0.18em] text-fondo/50">Teléfono / WhatsApp</label>
          <input
            type="tel"
            id="telefono"
            name="telefono"
            required
            class="mt-1.5 w-full border-0 bg-transparent p-0 font-display text-xl font-semibold tracking-tight text-fondo placeholder-fondo/30 focus:outline-none focus:ring-0"
            placeholder="668 123 4567"
          />
        </div>
        <div class="py-4">
          <label for="email" class="font-mono text-[11px] uppercase tracking-[0.18em] text-fondo/50">Correo</label>
          <input
            type="email"
            id="email"
            name="email"
            class="mt-1.5 w-full border-0 bg-transparent p-0 font-display text-xl font-semibold tracking-tight text-fondo placeholder-fondo/30 focus:outline-none focus:ring-0"
            placeholder="tu@correo.com"
          />
        </div>
        <div class="py-4">
          <label for="mensaje" class="font-mono text-[11px] uppercase tracking-[0.18em] text-fondo/50">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            required
            rows="3"
            class="mt-1.5 w-full resize-none border-0 bg-transparent p-0 text-base text-fondo placeholder-fondo/30 focus:outline-none focus:ring-0"
            placeholder="¿En qué podemos ayudarte?"
          ></textarea>
        </div>
        <div class="pt-6">
          <button type="submit" class="btn w-full justify-center bg-primario text-white hover:bg-secundario">
            Enviar mensaje
            <span class="font-mono">→</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
