---
/**
 * Variante CORPORATIVO del Hero.
 * Inspirado en dentalia.com + aspendental.com.
 * Layout 2-col asimétrico con eyebrow de oferta, h1 de beneficio,
 * doble CTA (WhatsApp + Llamar) y trust strip de señales de confianza.
 *
 * Campos opcionales en config:
 *   heroEyebrow?:  string        → pill de oferta sobre el h1
 *   heroTitulo?:   string        → h1 de beneficio (si no, usa business.nombre)
 *   heroTelefonoCta?: string     → texto del botón de llamar
 *   trustStrip?:   Array<{titulo, valor?, icono?}> → señales debajo del hero
 */
import { business } from '../../config';

const waHref = `https://wa.me/${business.whatsapp}?text=${encodeURIComponent(business.whatsappMensaje)}`;
const telHref = `tel:${business.telefono.replace(/\s/g, '')}`;

const tituloHero = business.heroTitulo ?? business.nombre;
const eyebrow = business.heroEyebrow;
const telCta = business.heroTelefonoCta ?? business.telefono;
const trust = business.trustStrip ?? [];

function iconPath(icono?: string) {
  switch (icono) {
    case 'rating':
      return 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.322.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z';
    case 'especialistas':
      return 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z';
    case 'anos':
      return 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z';
    case 'pagos':
      return 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z';
    case 'verificado':
      return 'M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z';
    default:
      return 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z';
  }
}
---

<section id="hero" class="relative bg-fondo pt-10 pb-12 md:pt-14 md:pb-16">
  <div class="wrap">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr_1fr] lg:gap-16">
      <div>
        {eyebrow && (
          <p data-reveal="up" style="--reveal-delay: 80ms;" class="mb-6 inline-flex items-center gap-2 rounded-full border border-primario/20 bg-primario/5 px-3 py-1.5 text-[12px] font-medium text-primario">
            <span class="h-1.5 w-1.5 rounded-full bg-primario"></span>
            {eyebrow}
          </p>
        )}
        <h1 data-reveal="up" style="--reveal-delay: 180ms;" class="mb-6 font-display text-[2.25rem] font-bold leading-[1.08] tracking-tight text-texto sm:text-5xl lg:text-[3.5rem]">
          {tituloHero}
        </h1>
        <p data-reveal="up" style="--reveal-delay: 320ms;" class="max-w-xl text-base leading-relaxed text-tenue md:text-lg">
          {business.descripcionCorta}
        </p>
        <div data-reveal="up" style="--reveal-delay: 460ms;" class="mt-8 flex flex-wrap items-center gap-3">
          <a href={waHref} target="_blank" rel="noopener" class="btn-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z" />
            </svg>
            {business.heroCtaTexto}
          </a>
          <a href={telHref} class="inline-flex items-center gap-2 rounded-full border border-texto/15 px-5 py-3 text-sm font-medium text-texto transition hover:border-primario hover:text-primario">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {telCta}
          </a>
        </div>
      </div>

      <figure data-reveal="image" style="--reveal-delay: 250ms;" class="reveal-image relative">
        <div class="aspect-[5/6] overflow-hidden figure-shape">
          <img
            src={business.heroImagen}
            alt={business.nombre}
            class="h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </figure>
    </div>

    {trust.length > 0 && (
      <div data-reveal="fade" style="--reveal-delay: 600ms;" class="mt-12 grid grid-cols-2 gap-6 rounded-2xl border border-linea bg-superficie/60 p-6 md:mt-16 md:grid-cols-4 md:p-8">
        {trust.map((item) => (
          <div class="flex items-center gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primario/10 text-primario">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPath(item.icono)} />
              </svg>
            </span>
            <div class="min-w-0">
              {item.valor && (
                <p class="font-display text-lg font-bold leading-tight text-texto">{item.valor}</p>
              )}
              <p class="text-[13px] leading-snug text-tenue">{item.titulo}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
