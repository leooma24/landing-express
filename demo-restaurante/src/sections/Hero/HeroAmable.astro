---
/**
 * Variante AMABLE del Hero.
 * Patrón Friendly Family Ortho extraído de myhappybraces, dunnortho, engortho, serrano.
 *
 * Layout: full-bleed photo background con dark warm gradient overlay,
 * headline sans bold blanco centrado-izquierda, subtitle blanco/translucent,
 * UN solo CTA pill grande primary, badges row de credenciales debajo,
 * blob decorativo sutil en esquina, no eyebrow-pill.
 *
 * Usa imagenHero como fondo full-bleed.
 */
import { business } from '../../config';

const waHref = `https://wa.me/${business.whatsapp}?text=${encodeURIComponent(business.whatsappMensaje)}`;
const telHref = `tel:${business.telefono.replace(/\s/g, '')}`;

const tituloHero = business.heroTitulo ?? business.nombre;
const eyebrow = business.heroEyebrow;
const trust = business.trustStrip ?? [];
---

<section id="hero" class="relative isolate min-h-[88vh] overflow-hidden bg-secundario text-white">
  {/* Background image full-bleed */}
  <div class="absolute inset-0 -z-10">
    <img
      src={business.heroImagen}
      alt={business.nombre}
      class="h-full w-full object-cover object-[center_30%]"
      loading="eager"
      fetchpriority="high"
    />
    {/* Warm dark gradient overlay for text legibility */}
    <div class="absolute inset-0 bg-gradient-to-b from-secundario/40 via-secundario/55 to-secundario/85"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-secundario/70 via-transparent to-transparent"></div>
  </div>

  {/* Decorative blob top-right */}
  <div class="pointer-events-none absolute -right-32 -top-32 h-80 w-80 rounded-full bg-acento/30 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-primario/40 blur-3xl"></div>

  <div class="wrap relative flex min-h-[88vh] flex-col justify-end pb-16 pt-32 md:pb-20 md:pt-36">
    <div class="max-w-3xl">
      {eyebrow && (
        <div data-reveal="up" style="--reveal-delay: 60ms;" class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-4 py-1.5 backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-acento"></span>
          <p class="text-[12px] font-medium tracking-wide text-white/95">
            {eyebrow}
          </p>
        </div>
      )}

      <h1
        data-reveal="up"
        style="--reveal-delay: 180ms;"
        class="hero-amable-h1 font-display font-bold leading-[1.02] tracking-tight text-white"
      >
        {tituloHero}
      </h1>

      <p
        data-reveal="up"
        style="--reveal-delay: 320ms;"
        class="mt-6 max-w-2xl text-base leading-relaxed text-white/85 md:text-lg"
      >
        {business.descripcionCorta}
      </p>

      <div data-reveal="up" style="--reveal-delay: 460ms;" class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href={waHref}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 bg-acento px-7 py-4 text-base font-semibold text-white shadow-[0_12px_32px_-8px_rgba(0,0,0,0.4)] transition-all duration-300 hover:bg-white hover:text-acento hover:-translate-y-0.5"
          style="border-radius: var(--radius-full);"
        >
          <span>{business.heroCtaTexto}</span>
          <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
        <a
          href={telHref}
          class="group inline-flex items-center gap-2.5 px-2 py-2 text-[15px] font-medium text-white/95 transition hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <span class="border-b border-white/40 pb-0.5">{business.telefono}</span>
        </a>
      </div>
    </div>

    {/* Trust badges row — separated bottom strip */}
    {trust.length > 0 && (
      <div data-reveal="fade" style="--reveal-delay: 700ms;" class="mt-16 grid grid-cols-2 gap-x-6 gap-y-5 border-t border-white/15 pt-8 md:mt-20 md:grid-cols-4 md:gap-x-10">
        {trust.map((item) => (
          <div class="flex items-start gap-3">
            <span class="mt-1 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
            </span>
            <div class="min-w-0">
              {item.valor && (
                <p class="font-display text-base font-bold leading-tight text-white">{item.valor}</p>
              )}
              <p class="text-[12px] leading-snug text-white/75 md:text-[13px]">
                {item.titulo}
              </p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .hero-amable-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }
</style>
