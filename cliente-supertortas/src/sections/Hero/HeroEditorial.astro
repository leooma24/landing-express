---
import { business } from '../../config';

const waHref = `https://wa.me/${business.whatsapp}?text=${encodeURIComponent(business.whatsappMensaje)}`;
const anoActual = new Date().getFullYear();
---

<section id="hero" class="bg-fondo pt-12 pb-20 md:pt-16 md:pb-28">
  <div class="wrap">
    <div class="mb-10 flex items-baseline justify-between border-b border-linea pb-4" data-reveal="fade">
      <p class="meta-label">
        {business.direccion.ciudad} · {business.direccion.estado}
      </p>
      <p class="meta-number">Est. {anoActual - 12} · {anoActual}</p>
    </div>

    <div class="grid items-end gap-10 lg:grid-cols-[1.3fr_1fr] lg:gap-16">
      <div>
        <p data-reveal="left" style="--reveal-delay: 100ms;" class="mb-6 font-mono text-[11px] uppercase tracking-[0.2em] text-primario">
          {business.tagline}
        </p>
        <h1 data-reveal="left" style="--reveal-delay: 220ms;" class="mb-8 font-display text-display-xl font-semibold text-texto">
          {business.nombre}
        </h1>
        <p data-reveal="left" style="--reveal-delay: 360ms;" class="max-w-xl text-base leading-relaxed text-tenue md:text-lg">
          {business.descripcionCorta}
        </p>
        <div data-reveal="left" style="--reveal-delay: 500ms;" class="mt-10 flex flex-wrap items-center gap-3">
          <a href={waHref} target="_blank" rel="noopener" class="btn-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z" />
            </svg>
            {business.heroCtaTexto}
          </a>
          <a href="#servicios" class="btn-ghost">
            Ver servicios
            <span class="font-mono transition group-hover:translate-y-0.5">↓</span>
          </a>
        </div>
      </div>

      <figure data-reveal="image" style="--reveal-delay: 350ms;" class="reveal-image relative">
        <div class="aspect-[4/5] overflow-hidden figure-shape">
          <img
            src={business.heroImagen}
            alt={business.nombre}
            class="h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        {business.mostrarNumeros && (
          <figcaption class="mt-3 flex items-baseline justify-between font-mono text-[11px] uppercase tracking-[0.15em] text-tenue">
            <span>Fig. 01</span>
            <span>{business.direccion.ciudad}</span>
          </figcaption>
        )}
      </figure>
    </div>
  </div>
</section>
