---
/**
 * Servicios — variante IMAGE CARDS.
 * 4 cards con imagen header, título, descripción corta, link.
 * Patrón Friendly Family Ortho.
 */
import { business } from '../../config';

const items = business.servicios;
const fallbackImg = 'https://images.unsplash.com/photo-1606811971618-4486d14f3f99?w=600&q=80';
---

<section id="servicios" class="section-pad bg-fondo">
  <div class="wrap">
    <div class="mx-auto mb-16 max-w-2xl text-center md:mb-20">
      <p data-reveal="up" class="font-mono text-[11px] font-semibold uppercase tracking-[0.24em] text-primario">
        Servicios
      </p>
      <h2 data-reveal="up" style="--reveal-delay: 100ms;" class="mt-4 font-display text-3xl font-bold tracking-tight text-texto md:text-[2.5rem] md:leading-tight">
        Tratamientos para cada sonrisa
      </h2>
      <p data-reveal="up" style="--reveal-delay: 200ms;" class="mt-5 text-base leading-relaxed text-tenue md:text-lg">
        Soluciones completas con tecnología digital — desde el primer diagnóstico hasta los retenedores finales.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      {items.map((s, i) => (
        <article
          data-reveal="up"
          style={`--reveal-delay: ${i * 80}ms;`}
          class="group flex flex-col overflow-hidden bg-fondo shadow-[0_4px_20px_-8px_rgba(14,165,233,0.12)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_24px_60px_-15px_rgba(14,165,233,0.28)]"
          style-extra="border-radius: var(--radius-lg);"
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src={s.imagen ?? fallbackImg}
              alt={s.titulo}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-secundario/40 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </div>
          <div class="flex flex-1 flex-col p-7">
            <h3 class="font-display text-xl font-bold leading-tight text-texto md:text-[1.4rem]">
              {s.titulo}
            </h3>
            <p class="mt-3 flex-1 text-[14px] leading-relaxed text-tenue md:text-[15px]">
              {s.descripcion}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  #servicios article { border-radius: var(--radius-lg); }
</style>
