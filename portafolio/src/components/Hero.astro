---
import { site, paquete } from '../config';
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section id="inicio" class="relative overflow-hidden bg-bone pt-24 pb-32 md:pt-32 md:pb-40">
  <div class="wrap">
    <div class="mb-12 flex items-center gap-4">
      <span class="flex h-2 w-2 rounded-full bg-coral">
        <span class="h-full w-full animate-ping rounded-full bg-coral"></span>
      </span>
      <p class="meta-label">Local · {site.ciudad}, Sinaloa</p>
    </div>

    <h1 class="mb-8 text-display-xl font-black text-ink-900 font-display max-w-4xl">
      Páginas web que <span class="relative inline-block">
        <span class="relative z-10 italic">sí</span>
        <svg class="absolute -bottom-1 left-0 h-2.5 w-full text-coral" viewBox="0 0 100 12" preserveAspectRatio="none">
          <path d="M0,8 Q25,2 50,6 T100,5" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
        </svg>
      </span> traen clientes.
    </h1>

    <div class="grid gap-12 border-t border-ink-200 pt-12 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <p class="max-w-xl text-base leading-relaxed text-ink-500 md:text-lg">
          Una landing que funciona mientras duermes. Dominio, hosting, WhatsApp y Google Maps — todo conectado para que <span class="text-ink-900">la gente te encuentre</span> cuando te busca.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href={waHref} target="_blank" rel="noopener" class="btn-ink">
            Hablemos por WhatsApp
            <span class="font-mono">→</span>
          </a>
          <a href="#demos" class="btn-ghost">Ver ejemplos</a>
        </div>
      </div>

      <aside class="grid grid-cols-2 gap-0 divide-x divide-y divide-ink-200 border-y border-ink-200 lg:border-y-0">
        <div class="py-5 pr-5 lg:py-0 lg:pr-6">
          <p class="meta-label mb-2">Inversión</p>
          <p class="font-display text-3xl font-bold tracking-tightest">${paquete.precioSetup.toLocaleString('es-MX')}</p>
          <p class="mt-1 font-mono text-[11px] text-ink-400">MXN pago único</p>
        </div>
        <div class="py-5 pl-5 lg:py-0 lg:pl-6">
          <p class="meta-label mb-2">Mensual</p>
          <p class="font-display text-3xl font-bold tracking-tightest">${paquete.precioMensual}</p>
          <p class="mt-1 font-mono text-[11px] text-ink-400">MXN/mes</p>
        </div>
        <div class="py-5 pr-5 lg:py-0 lg:pr-6">
          <p class="meta-label mb-2">Entrega</p>
          <p class="font-display text-3xl font-bold tracking-tightest">3–5</p>
          <p class="mt-1 font-mono text-[11px] text-ink-400">días hábiles</p>
        </div>
        <div class="py-5 pl-5 lg:py-0 lg:pl-6">
          <p class="meta-label mb-2">Permanencia</p>
          <p class="font-display text-3xl font-bold tracking-tightest">0</p>
          <p class="mt-1 font-mono text-[11px] text-ink-400">sin contratos</p>
        </div>
      </aside>
    </div>
  </div>
</section>
