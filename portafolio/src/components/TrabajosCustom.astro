---
import { demos, customTier, site } from '../config';

const custom = demos.filter((d) => d.tipo === 'producto');
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent('Hola, me interesa un proyecto a medida, no una landing.')}`;
---

<section id="custom" class="relative overflow-hidden bg-ink-900 py-24 text-bone md:py-40">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(rgba(255,255,255,0.6) 1.2px, transparent 1.2px); background-size: 32px 32px;"
  ></div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-32 top-1/4 h-[32rem] w-[32rem] rounded-full bg-coral opacity-15 blur-[140px]"
  ></div>

  <div class="wrap relative">
    <div class="mb-16 flex items-baseline justify-between border-b border-bone/10 pb-6">
      <p class="meta-label text-bone/50">03 · Proyectos a medida</p>
      <p class="meta-number text-bone/50">
        Desde ${customTier.precioDesde.toLocaleString('es-MX')} MXN
      </p>
    </div>

    <div class="mb-16 grid items-end gap-8 lg:grid-cols-2">
      <h2 class="font-display text-display font-black tracking-tightest text-bone">
        Cuando una landing<br />
        <span class="text-coral">no alcanza.</span>
      </h2>
      <div class="max-w-md">
        <p class="text-base text-bone/70 md:text-lg">
          {customTier.descripcionLarga}
        </p>
        <div class="mt-5 flex flex-wrap gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-bone/50">
          <span class="rounded-full border border-bone/20 px-3 py-1">SaaS / Dashboards</span>
          <span class="rounded-full border border-bone/20 px-3 py-1">CRM / Backoffice</span>
          <span class="rounded-full border border-bone/20 px-3 py-1">APIs / Integraciones</span>
        </div>
      </div>
    </div>

    <div class="space-y-12">
      {custom.map((d, i) => (
        <a href={d.url} target="_blank" rel="noopener" class="group block">
          <div class="mb-6 flex items-baseline justify-between border-b border-bone/10 pb-4">
            <div class="flex items-baseline gap-6">
              <span class="font-mono text-sm font-medium text-bone/40 tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <div class="mb-1 flex items-center gap-3">
                  <p class="meta-label text-bone/50">{d.rubro}</p>
                  <span class="inline-flex items-center gap-1 rounded-full bg-coral/15 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.15em] text-coral">
                    Producto propio
                  </span>
                </div>
                <h3 class="font-display text-2xl font-bold tracking-tightest text-bone md:text-3xl">
                  {d.negocio}
                </h3>
              </div>
            </div>
            <span class="hidden items-center gap-2 font-mono text-xs text-bone/40 group-hover:text-coral md:inline-flex">
              {d.url.replace('https://', '')}
              <span class="transition group-hover:translate-x-1">↗</span>
            </span>
          </div>

          <div class="overflow-hidden rounded-2xl border border-bone/10 bg-bone/5 shadow-[0_30px_80px_-20px_rgba(0,0,0,0.4)] transition group-hover:border-bone/20">
            <div class="flex h-9 items-center gap-1.5 border-b border-bone/10 bg-bone/5 px-4">
              <span class="h-2.5 w-2.5 rounded-full bg-bone/20"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-bone/20"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-bone/20"></span>
              <div class="ml-4 flex-1">
                <div class="mx-auto w-fit rounded-md bg-bone/10 px-3 py-1 font-mono text-[10px] text-bone/60">
                  {d.url.replace('https://', '')}
                </div>
              </div>
            </div>

            {d.imagen ? (
              <div class="relative aspect-[16/9] overflow-hidden bg-ink-800">
                <img
                  src={d.imagen}
                  alt={`Screenshot de ${d.negocio}`}
                  class="h-full w-full object-cover object-top transition duration-700 group-hover:scale-[1.02]"
                  loading="lazy"
                />
                <div class="absolute left-6 top-6 flex items-center gap-2 rounded-full bg-ink-900/70 px-3 py-1.5 backdrop-blur">
                  <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-white">Producto en vivo</span>
                </div>
              </div>
            ) : (
              <div class="relative flex aspect-[16/9] items-center justify-center overflow-hidden bg-gradient-to-br from-coral/20 via-ink-800 to-ink-900">
                <p class="font-display text-5xl font-black text-bone">{d.negocio}</p>
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-6 border-t border-bone/10 pt-10 sm:flex-row sm:items-center">
      <div>
        <p class="mb-1 meta-label text-bone/50">¿Tu proyecto necesita algo similar?</p>
        <p class="font-display text-xl font-semibold text-bone md:text-2xl">
          Hablemos del alcance y te cotizo.
        </p>
      </div>
      <a href={waHref} target="_blank" rel="noopener" class="btn-coral shrink-0">
        Cotizar proyecto
        <span class="font-mono">→</span>
      </a>
    </div>
  </div>
</section>
