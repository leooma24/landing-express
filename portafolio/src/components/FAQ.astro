---
import { faqs, site } from '../config';
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section id="faq" class="bg-bone py-24 md:py-40">
  <div class="wrap">
    <div class="mb-16 flex items-baseline justify-between border-b border-ink-200 pb-6">
      <p class="meta-label">05 · Preguntas</p>
      <p class="meta-number">{faqs.length}</p>
    </div>

    <div class="grid gap-16 lg:grid-cols-[1fr_1.6fr] lg:gap-24">
      <div class="lg:sticky lg:top-24 lg:self-start">
        <h2 class="font-display text-display-sm font-black tracking-tightest">
          Lo que<br />
          todos<br />
          preguntan.
        </h2>
        <p class="mt-6 max-w-sm text-sm text-ink-500 md:text-base">
          Si tienes otra duda no listada, escríbenos directo por WhatsApp.
        </p>
        <a href={waHref} target="_blank" rel="noopener" class="btn-ghost mt-8">
          Escribir
          <span class="font-mono">→</span>
        </a>
      </div>

      <div class="divide-y divide-ink-200 border-y border-ink-200">
        {faqs.map((f, i) => (
          <details class="group py-8" open={i === 0}>
            <summary class="flex cursor-pointer items-start justify-between gap-8 text-left">
              <div class="flex items-start gap-6">
                <span class="font-mono text-xs font-medium text-ink-400 tabular-nums pt-2">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="font-display text-lg font-bold leading-snug tracking-tightest md:text-xl">
                  {f.pregunta}
                </h3>
              </div>
              <span class="mt-2 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-ink-200 text-ink-500 transition group-open:rotate-45 group-open:border-coral group-open:bg-coral group-open:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
                  <path d="M10 4v12M4 10h12" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <p class="mt-4 pl-12 text-[15px] leading-relaxed text-ink-500">
              {f.respuesta}
            </p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
