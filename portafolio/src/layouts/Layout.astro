---
import { site } from '../config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? site.seo.titulo;
const pageDescription = description ?? site.seo.descripcion;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
const animacionesEntrada = site.animaciones?.entrada !== false;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL(site.seo.ogImagen, Astro.site).toString()} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#0a0a0a" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {animacionesEntrada && (
      <script is:inline>document.documentElement.classList.add('js-reveal');</script>
    )}
  </head>
  <body>
    <slot />

    <a
      href={waHref}
      target="_blank"
      rel="noopener"
      aria-label="Contactar por WhatsApp"
      class="group fixed bottom-6 right-6 z-50 flex h-14 items-center gap-3 rounded-full bg-ink-900 pl-5 pr-6 text-bone shadow-[0_20px_50px_-15px_rgba(10,10,10,0.5)] transition hover:bg-coral hover:shadow-[0_20px_50px_-15px_rgba(255,77,31,0.5)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
        <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z" />
      </svg>
      <span class="font-mono text-[11px] font-medium uppercase tracking-[0.15em]">WhatsApp</span>
    </a>
    {animacionesEntrada && (
      <script is:inline>
        (function () {
          const selector = 'section h1, section h2, section h3, section p, section li, section img, section article, section figure, [data-reveal]';
          const targets = Array.from(document.querySelectorAll(selector)).filter(
            (el) => !el.hasAttribute('data-no-reveal') && !el.closest('[data-no-reveal]')
          );

          if (!('IntersectionObserver' in window)) {
            targets.forEach((el) => el.classList.add('is-visible'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.08, rootMargin: '0px 0px -80px 0px' }
          );
          targets.forEach((el) => io.observe(el));
        })();
      </script>
    )}
  </body>
</html>
